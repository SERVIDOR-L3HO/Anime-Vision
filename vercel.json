{
  "buildCommand": "pnpm --filter @workspace/anime-world run build:vercel",
  "outputDirectory": "artifacts/anime-world/dist",
  "framework": null,
  "installCommand": "pnpm install",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 60,
      "includeFiles": "artifacts/api-server/src/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
